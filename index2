  left: 25px;
  z-index: 10001;
}

.video-fullscreen-info .grid-title {
  color: #fff;
  font-family: var(--font-display);
  font-size: 1.2rem;
  font-weight: 600;
}

.video-fullscreen-info .grid-cat {
  color: rgba(255,255,255,0.5);
  font-size: 0.8rem;
  margin-top: 4px;
}

@media (max-width: 600px) {
  .video-fullscreen-controls .vc-progress {
    width: 120px;
  }
  .video-fullscreen-overlay video {
    max-width: 100vw;
    max-height: 80vh;
    border-radius: 0;
  }
}

