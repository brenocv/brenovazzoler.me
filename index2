.reveal.visible {
  opacity: 1;
  transform: translateY(0);
}



/* --- HAMBURGER (mobile) --- */
.hamburger {
  display: none;
  flex-direction: column;
  gap: 6px;
  background: none;
  border: none;
  padding: 10px;
  cursor: pointer;
  z-index: 1001;
  position: relative;
  touch-action: manipulation;
  min-width: 44px;
  min-height: 44px;
  align-items: center;
  justify-content: center;
}

.hamburger span {
  display: block;
  width: 28px;
  height: 2px;
  background: white;
  transition: transform 0.3s, opacity 0.3s;
  border-radius: 2px;
}

.hamburger.open span:nth-child(1) { transform: translateY(8px) rotate(45deg); }
.hamburger.open span:nth-child(2) { opacity: 0; }
