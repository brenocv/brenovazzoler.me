<style>

:root {
  --bg-dark: #050505;
  --bg-card: #000000;
  --primary: #AAAAAA;
  --primary-dim: #444444;
  --text-main: #f0f0f0;
  --text-muted: #888;
  --font-display: 'Syne', sans-serif;
  --font-body: 'Space Grotesk', sans-serif;
  --font-special: 'Doto', sans-serif;
  --cursor-size: 20px;
  --header-height: 90px;
  --section-gap: 80px;
}

* {
  margin: 0;
  padding: 0;
  box-sizing: border-box;
}

html { scroll-behavior: smooth; }
.hero-role-link {
  color: inherit;
  text-decoration: none;
  transition: color 0.3s ease, transform 0.3s ease;
  display: inline-block;
  cursor: pointer;
}
.hero-role-link:hover {
  color: var(--primary);
  transform: scale(1.05);
}
.hero-role-link.h1-alt:hover {
  color: var(--primary);
}


body {
  font-family: var(--font-body);
  background-color: var(--bg-dark);
  color: var(--text-main);
  overflow-x: hidden;
  -webkit-font-smoothing: antialiased;
}

/* --- CUSTOM CURSOR --- */
.cursor {
  position: fixed;
  top: 0; left: 0;
  width: var(--cursor-size);
  height: var(--cursor-size);
  border: 1px solid var(--text-main);
  border-radius: 50%;
  pointer-events: none;
  z-index: 9999;
  transform: translate(-50%, -50%);
  transition: width 0.3s, height 0.3s, background-color 0.3s;
  mix-blend-mode: difference;
}

.cursor.hovered {
  width: 60px; height: 60px;
  background-color: var(--text-main);
  border-color: transparent;
}

/* --- FLUID BACKGROUND CANVAS --- */
#hero {
  position: relative;
  overflow: hidden;
}
#fluid-canvas {
  position: absolute;
  top: 0; left: 0;
  width: 100%; height: 100%;
  z-index: 0;
  opacity: 0.6;
  filter: blur(60px) contrast(8);
}

/* --- HEADER --- */
header {
  position: fixed;
  top: 0; width: 100%;
  height: var(--header-height);
  padding: 0 50px;
  display: flex;
  justify-content: space-between;
  align-items: center;
  z-index: 100;
  background-color: rgba(17, 17, 17, 0.85);
  backdrop-filter: blur(10px);
  -webkit-backdrop-filter: blur(10px);
  border-bottom: 1px solid rgba(255,255,255,0.05);
}

.logo-container {
  position: relative; z-index: 2;
  text-decoration: none; color: white;
  display: flex; align-items: center; gap: 10px;
}

.logo-text {
  font-family: var(--font-display);
  font-weight: 800; font-size: 1.6rem;
  letter-spacing: -2px; text-transform: uppercase;
  line-height: 1; transition: transform 0.2s ease-out;
  position: relative; color: white;
}

.rec-dot {
  width: 12px; height: 12px;
  background-color: #C62828;
  border-radius: 50%;
  display: inline-block; flex-shrink: 0;
  animation: pulse 2s infinite;
}

@keyframes pulse {
  0%   { box-shadow: 0 0 0 0 rgba(255, 31, 31, 0.7); }
  70%  { box-shadow: 0 0 0 10px rgba(255, 31, 31, 0); }
  100% { box-shadow: 0 0 0 0 rgba(255, 31, 31, 0); }
}

nav ul {
  display: flex; list-style: none; gap: 40px;
}

nav a {
  font-family: var(--font-body);
  color: white; text-decoration: none;
  font-weight: 500; font-size: 0.85rem;
  text-transform: uppercase; letter-spacing: 1px;
  position: relative;
}

nav a::before {
  content: '';
  position: absolute;
  bottom: -5px; left: 0;
  width: 0%; height: 1px;
  background: var(--primary);
  transition: width 0.3s ease;
}

nav a:hover::before { width: 100%; }

/* --- NAV DROPDOWN (Portfolio) --- */
.nav-dropdown {
  position: relative;
}
.nav-dropdown-menu {
  position: absolute;
  top: 100%;
  left: 50%;
  min-width: 220px;
  background: rgba(10, 10, 10, 0.95);
  backdrop-filter: blur(16px);
  -webkit-backdrop-filter: blur(16px);
  border: 1px solid rgba(255,255,255,0.08);
  border-radius: 8px;
  padding: 8px 0;
  opacity: 0;
  visibility: hidden;
  transform: translateX(-50%) translateY(8px);
  transition: opacity 0.3s ease, visibility 0.3s ease, transform 0.3s ease;
  z-index: 200;
}
.nav-dropdown:hover .nav-dropdown-menu,
.nav-dropdown.open .nav-dropdown-menu {
  opacity: 1;
  visibility: visible;
  transform: translateX(-50%) translateY(0);
}
.nav-dropdown-menu a {
  display: block;
  padding: 10px 20px;
  font-family: var(--font-body);
  font-size: 0.8rem;
  text-transform: uppercase;
  letter-spacing: 1px;
  color: rgba(255,255,255,0.7);
  text-decoration: none;
  transition: color 0.3s, background 0.3s;
  white-space: nowrap;
}
.nav-dropdown-menu a:hover {
  color: #fff;
  background: rgba(255,255,255,0.06);
}
.nav-dropdown-menu a::before { display: none; }

/* --- MOBILE NAV DROPDOWN --- */
.mobile-nav-dropdown {
  position: relative;
}
.mobile-nav-dropdown-trigger {
  cursor: pointer;
 }
.mobile-nav-dropdown-menu {
  max-height: 0;
  overflow: hidden;
  transition: max-height 0.4s ease;
  padding-left: 20px;
}
.mobile-nav-dropdown.open .mobile-nav-dropdown-menu {
  max-height: 300px;
}
.mobile-nav-dropdown-menu a {
  display: block;
  font-size: 1.4rem;
  padding: 8px 0;
  opacity: 0.7;
  transition: opacity 0.3s;
}
.mobile-nav-dropdown-menu a:hover {
  opacity: 1;
}

/* --- HERO SECTION --- */
#hero {
  position: relative;
  padding-top: calc(var(--header-height) + var(--section-gap));
  padding-bottom: var(--section-gap);
  width: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1;
}

.hero-text {
  z-index: 2; position: relative;
  text-align: center;
  max-width: 1200px;
  padding: 0 20px;
  mix-blend-mode: exclusion;
}

h1 {
  font-family: var(--font-display);
  font-size: 3.2rem; line-height: 0.9;
  font-weight: 800; text-transform: uppercase;
  color: white;
  text-shadow: 0 10px 30px rgba(0,0,0,0.5);
  transform-style: preserve-3d;
  perspective: 1000px;
  letter-spacing: -2px;
}

.h1-alt {
  color: #999999;
}

.doto-text {
  font-family: var(--font-special);
  font-size: 3.5rem; display: block;
  margin-top: 10px; color: var(--primary);
  letter-spacing: 2px; font-weight: 500;
}

.hero-sub {
  margin-top: 30px;
  font-family: var(--font-body);
  font-size: 1.125rem;
  color: rgba(255,255,255,0.85);
  font-weight: 300;
  letter-spacing: 0.5px;
  line-height: 1.5;
  text-align: center;
  text-transform: none;
}

/* --- VIDEO GRID (4 QUADRANTS) --- */
#video-grid {
  position: relative; z-index: 2;
  background: black; width: 100%;
}

.grid-container {
  display: grid;
  grid-template-columns: 1fr 1fr;
  grid-template-rows: 1fr 1fr;
  gap: 0;
  width: 100%;
}

/* Quadrant containers */
.quadrant {
  display: grid;
  overflow: hidden;
}
.quadrant-large {
  grid-template-columns: 1fr;
  grid-template-rows: 1fr;
}
.quadrant-small-grid {
  grid-template-columns: 1fr 1fr;
  grid-template-rows: 1fr 1fr;
  gap: 0;
}

.grid-item {
  position: relative;
  width: 100%;
  aspect-ratio: 16 / 9;
  background: #080808;
  overflow: hidden;
  border: none;
}

.grid-item-large { aspect-ratio: 16 / 9; }

/* Iframe styling */
.grid-item iframe,
.grid-item video {
  width: 100%; height: 100%;
  border: none;
  opacity: 0.7;
  transition: opacity 0.4s ease, transform 0.6s ease;
  filter: grayscale(100%);
  pointer-events: none;
  object-fit: cover;
}

.grid-item:hover iframe,
.grid-item:hover video {
  opacity: 1;
  filter: grayscale(0%);
  transform: scale(1.05);
}

/* Play overlay */
.play-overlay {
  position: absolute;
  top: 0; left: 0;
  width: 100%; height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(0,0,0,0.3);
  opacity: 0;
  transition: opacity 0.4s ease;
  z-index: 5;
  cursor: pointer;
}

.grid-item:hover .play-overlay,
.grid-item.playing:hover .play-overlay {
  opacity: 1;
}

.grid-item.playing .play-overlay {
  opacity: 0;
  pointer-events: none;
}

.grid-item.playing:hover .play-overlay {
  opacity: 0;
  pointer-events: none;
}

/* Video controls — only visible after play click */
.video-controls {
  position: absolute;
  bottom: 0; left: 0;
  width: 100%;
  display: flex;
  align-items: center;
  gap: 6px;
  padding: 6px 10px;
  background: linear-gradient(transparent, rgba(0,0,0,0.85));
  z-index: 6;
  opacity: 0;
  pointer-events: none;
  transition: opacity 0.4s ease;
  box-sizing: border-box;
}

/* --- VIDEO FULLSCREEN OVERLAY --- */
.video-fullscreen-overlay {
  position: fixed;
  top: 0; left: 0;
  width: 100vw; height: 100vh;
  background: rgba(0, 0, 0, 0.92);
  z-index: 9999;
  display: flex;
  align-items: center;
  justify-content: center;
  opacity: 0;
  visibility: hidden;
  transition: opacity 0.5s ease, visibility 0.5s ease;
  backdrop-filter: blur(8px);
  -webkit-backdrop-filter: blur(8px);
}

.video-fullscreen-overlay.active {
  opacity: 1;
  visibility: visible;
}

.video-fullscreen-overlay video {
  max-width: 95vw;
  max-height: 90vh;
  width: auto;
  height: auto;
  aspect-ratio: 16 / 9;
  object-fit: contain;
  filter: none;
  opacity: 1;
  transform: none;
  border-radius: 8px;
  box-shadow: 0 0 60px rgba(0,0,0,0.8);
}

.video-fullscreen-controls {
  position: absolute;
  bottom: 30px;
  left: 50%;
  transform: translateX(-50%);
  display: flex;
  align-items: center;
  gap: 12px;
  padding: 10px 20px;
  background: rgba(0,0,0,0.7);
  border-radius: 50px;
  z-index: 10000;
}

.video-fullscreen-controls .vc-btn {
